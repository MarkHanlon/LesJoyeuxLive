{
  "expo": {
    "name": "LesJoyeuxLive",
    "slug": "les-joyeux-live",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Les Joyeux Live",
      "shortName": "JoyeuxLive",
      "description": "Family organization app — calendar, tasks, shopping lists, and more.",
      "lang": "en",
      "themeColor": "#4A90D9",
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "lesjoyeuxlive"
  }
}
