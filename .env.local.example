# Neon Postgres connection string
# IMPORTANT: Never commit the actual .env.local file
# This should only be accessed from API routes (app/api/*+api.ts)
#
# When provisioned via the Vercel Marketplace (vercel integration add neon),
# this variable is injected automatically into your Vercel project.
# Pull locally with: vercel env pull .env.local

DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"
